erDiagram
	direction LR
	USER {
		int user_id PK
		string username
		string email
		string password
		enum profile_type "buyer | agency | admin"
	}

	PROPERTY {
		int property_id PK
		enum property_type
		float price
		string address
		string city
		string province
		float area_sq
		int rooms
		string description
		bool available
		int agency_id FK
	}

	FAVORITE {
		int favorite_id PK
		int user_id FK
		int property_id FK
		date saved_date
		float saved_price
		int score
		string comment
	}

	PURCHASE {
		int purchase_id PK
		int user_id FK
		int property_id FK
		float purchase_price
		date purchase_date
	}

	USER||--o{PROPERTY:"searches (as buyer)"
	USER||--o{FAVORITE:"saves (as buyer)"
	USER||--o{PURCHASE:"makes (as buyer)"
	USER||--o{PROPERTY:"lists (as agency)"
	USER||--o{USER:"manages (as admin)"
	USER||--o{FAVORITE:"views (as admin)"
	USER||--o{PURCHASE:"views (as admin)"
	PROPERTY||--o{FAVORITE:"appears in"
	PROPERTY||--o|PURCHASE:"acquired in"
